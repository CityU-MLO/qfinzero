# UPQ Service Configuration
# Copy this file to .env and modify values as needed

# Server port (default: 23333)
PORT=19350

# Storage root directory for parquet files (required)
# This should point to the directory containing ingested data
STORAGE_ROOT=/home/qlib/upq_storage

# Log level (default: info)
# Options: trace, debug, info, warn, error
RUST_LOG=info

# Optional: Manifest database path for ingest
# MANIFEST_PATH=/home/qlib/upq_state/manifest.sqlite

# Optional: Raw data root for ingest
# RAW_ROOT=/home/qlib/upq_data
