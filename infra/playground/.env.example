# Playground service configuration
# Copy to .env and adjust for your environment.
# .env is git-ignored (machine-specific).

# Service listen address (default: 0.0.0.0:19310)
# PLAYGROUND_PORT=19310
# PLAYGROUND_HOST=0.0.0.0

# Backend service URLs
# Production ports (default, no override needed on prod):
#   QFINZERO_UPQ_URL=http://127.0.0.1:19350
#   QFINZERO_NPP_URL=http://127.0.0.1:19330
#   QFINZERO_PMB_URL=http://127.0.0.1:19320
#
# Dev / SSH-tunnel ports (uncomment when running locally with tunnel):
# QFINZERO_UPQ_URL=http://127.0.0.1:19703
# QFINZERO_NPP_URL=http://127.0.0.1:19702
# QFINZERO_PMB_URL=http://127.0.0.1:19701

# Agent request timeout in seconds (default: 120)
# PLAYGROUND_TIMEOUT_S=120
