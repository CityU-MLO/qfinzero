# Playground service configuration
# Copy to .env and adjust for your environment.
# .env is git-ignored (machine-specific).

# Service listen address (default: 0.0.0.0:19390)
# PLAYGROUND_PORT=19390
# PLAYGROUND_HOST=0.0.0.0

# Backend service URLs (193xx block; defaults, no override needed on prod):
#   QFINZERO_UPQ_URL=http://127.0.0.1:19350
#   QFINZERO_ESP_URL=http://127.0.0.1:19330
#   QFINZERO_PMB_URL=http://127.0.0.1:19380
#
# Override these if running locally against an SSH tunnel on different ports.

# Agent request timeout in seconds (default: 120)
# PLAYGROUND_TIMEOUT_S=120
