# QFinZero global service configuration
# Override any value via environment variables as needed.

# Service host (used by scripts and client defaults)
QFZ_HOST=127.0.0.1

# Service ports (193xx block)
DASHBOARD_PORT=19300
PMB_PORT=19380
ESP_PORT=19330
UPQ_PORT=19350
PLAYGROUND_PORT=19390

# QFinZero data root (all owned data lives here: upq/ esp/ raw/)
QFZ_DATA_ROOT=/data/qfinzero

# ESP event databases (under $QFZ_DATA_ROOT/esp)
EARNINGS_DB=/data/qfinzero/esp/benzinga_earnings.sqlite3
ECON_EVENTS_DB=/data/qfinzero/esp/nasdaq_econ_events.sqlite3

# Data pipeline: raw vendor sources (read in place) + UPQ storage output.
# STORAGE_ROOT is also read by the UPQ service; keep them aligned.
RAW_MASSIVE_DIR=/data/massive_data
RAW_TUSHARE_DIR=/data/tushare_data
STORAGE_ROOT=/data/qfinzero/upq

# ESP data sources
MONGO_URI=mongodb://localhost:27018
MONGO_DB=market_news
MONGO_COLLECTION=ticker_news

# ── LLM egress proxy ─────────────────────────────────────────────
# Route OUTBOUND LLM API calls (OpenAI/Anthropic/…) through an HTTP proxy while
# intra-cluster calls (PMB/ESP/UPQ) stay direct. Consumed by the CLI eval runner
# and the Playground service. Falls back to HTTPS_PROXY/HTTP_PROXY when unset.
# LLM_PROXY=http://aiuser:ainewpass123@localhost:3128
# NO_PROXY=localhost,127.0.0.1,.cityu.edu.hk,192.168.0.0/16,10.0.0.0/8
