# QFinZero global service configuration
# Override any value via environment variables as needed.

# Service host (used by scripts and client defaults)
QFZ_HOST=127.0.0.1

# Service ports
PMB_PORT=19320
NPP_PORT=19330
UPQ_PORT=19350
DASHBOARD_PORT=19380

# Data paths (relative to repo root)
DATA_DIR=data
EARNINGS_DB=data/benzinga_earnings.sqlite3
ECON_EVENTS_DB=data/nasdaq_econ_events.sqlite3

# NPP data sources
MONGO_URI=mongodb://localhost:27018
MONGO_DB=market_news
MONGO_COLLECTION=ticker_news
