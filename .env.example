# QFinZero local service overrides
# Copy to `.env` and edit locally if you need custom ports or service URLs.

QFZ_HOST=127.0.0.1

DASHBOARD_PORT=19300
PMB_PORT=19380
ESP_PORT=19330
UPQ_PORT=19350
PLAYGROUND_PORT=19390
DATA_ADMIN_PORT=19340

# data-admin base URL for the dashboard-web /data page (defaults to QFZ_HOST:DATA_ADMIN_PORT)
# DATA_ADMIN_BASE_URL=http://127.0.0.1:19340

# ── Data ─────────────────────────────────────────────────────────
# All QFinZero-owned data lives under QFZ_DATA_ROOT (upq/ esp/ raw/).
QFZ_DATA_ROOT=/data/qfinzero
STORAGE_ROOT=/data/qfinzero/upq
EARNINGS_DB=/data/qfinzero/esp/benzinga_earnings.sqlite3
ECON_EVENTS_DB=/data/qfinzero/esp/nasdaq_econ_events.sqlite3
# Shared raw vendor sources (read in place, never copied):
RAW_MASSIVE_DIR=/data/massive_data
RAW_TUSHARE_DIR=/data/tushare_data

# ── LLM egress proxy ─────────────────────────────────────────────
# Route OUTBOUND LLM API calls (OpenAI/Anthropic/…) through an HTTP proxy while
# local service calls stay direct. Used by the CLI eval runner and the Playground
# service (Chat + Settings "Test connection"). If unset, the standard
# HTTPS_PROXY/HTTP_PROXY are used as a fallback. Keep local hosts in NO_PROXY.
# LLM_PROXY=http://aiuser:ainewpass123@localhost:3128
# NO_PROXY=localhost,127.0.0.1,.cityu.edu.hk,192.168.0.0/16,10.0.0.0/8
